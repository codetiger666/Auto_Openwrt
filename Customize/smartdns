config smartdns
        option enabled '1'
        option server_name 'smartdns'
        option port '5333'
        option auto_set_dnsmasq '1'
        option tcp_server '1'
        option tls_server '0'
        option doh_server '0'
        option ipv6_server '1'
        option bind_device '0'
        option dualstack_ip_selection '1'
        option serve_expired '0'
        option cache_persist '0'
        option resolve_local_hostnames '1'
        option force_https_soa '1'
        option rr_ttl_min '600'
        option seconddns_port '6553'
        option seconddns_tcp_server '1'
        option log_output_mode 'syslog'
        option speed_check_mode 'tcp:443,tcp:80,ping'
        option response_mode 'fastest-ip'
        option cache_size '0'
        option enable_auto_update '1'
        option auto_update_week_time '*'
        option auto_update_day_time '5'
        option old_port '5333'
        option old_enabled '1'
        option old_auto_set_dnsmasq '1'

