# Add custom settings here.
# please read https://pymumu.github.io/smartdns/config/basic-config/
domain-set -name ad -file /etc/smartdns/domain-set/ad
domain-set -name cn -file /etc/smartdns/domain-set/cn
domain-rules /domain-set:cn/ -nameserver cn
address /domain-set:ad/#
# 私有域名规则(通配符*.私有域名)
domain-rules /私有域名/ -nameserver cn

# github加速域名
domain-rules /testingcf.jsdelivr.net/ -nameserver cn
domain-rules /mirror.ghproxy.com/ -nameserver cn
domain-rules /ghp.ci/ -nameserver cn
